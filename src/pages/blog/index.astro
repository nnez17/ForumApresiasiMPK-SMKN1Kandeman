---
import { Clock } from "@lucide/astro";
import { app } from "@/api/elysia";
import type { NewsItem } from "@/data/News";
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import BlogHero from "@/components/BlogHero.astro";
import BlogCard from "@/components/BlogCard.astro";

const response = await app.handle(
	new Request("http://localhost:4321/api/news"),
);
const result = await response.json();
const newsData: NewsItem[] = result.success ? result.data : [];

const newsItems = newsData.filter(
	(item) =>
		item.category?.toLowerCase() === "berita" ||
		item.category?.toLowerCase() === "article" ||
		!item.category,
);
---

<Layout>
    <Navbar />
    <main class="flex-1 bg-background">
        <BlogHero />

        <!-- News List -->
        <section class="py-16 sm:py-20">
            <div class="container mx-auto px-4">
                {newsItems.length > 0 ? (
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        {newsItems.map((news) => (
                            <BlogCard news={news} />
                        ))}
                    </div>
                ) : (
                    <div class="text-center py-20">
                        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-muted mb-4">
                            <Clock class="w-8 h-8 text-muted-foreground" />
                        </div>
                        <h2 class="text-xl font-bold text-foreground mb-2">Belum ada berita</h2>
                        <p class="text-muted-foreground">Silakan kembali lagi nanti untuk informasi terbaru.</p>
                    </div>
                )}
            </div>
        </section>
    </main>
</Layout>

<style>
    main {
        min-height: calc(100vh - 4rem - 300px);
    }
</style>

